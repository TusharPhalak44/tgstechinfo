# Cookie Consent Management System - Environment Variables

# ============================================
# Tracking Script IDs
# ============================================
# Add your actual tracking IDs below to enable tracking scripts

# Google Analytics 4
VITE_GA4_ID=G-XXXXXXXXXX

# Google Tag Manager
VITE_GTM_ID=GTM-XXXXXXX

# HubSpot Portal ID
VITE_HUBSPOT_ID=1234567

# Meta Pixel (Facebook)
VITE_META_PIXEL_ID=1234567890123456

# LinkedIn Insight Tag Partner ID
VITE_LINKEDIN_ID=1234567

# Microsoft Clarity Project ID
VITE_CLARITY_ID=abcdefg

# ============================================
# API Configuration
# ============================================
VITE_API_URL=http://localhost:5000

# ============================================
# Notes
# ============================================
# - Leave tracking IDs empty if not using that service
# - Scripts will only load when user gives consent for the respective category
# - Analytics scripts require analytics_cookies consent
# - Marketing scripts require marketing_cookies consent
# - Functional scripts require functional_cookies consent
